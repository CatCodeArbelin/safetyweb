# Telegram bot token from BotFather.
BOT_TOKEN=

# PostgreSQL connection settings.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=safetyweb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Redis connection URL.
REDIS_URL=redis://localhost:6379/0

# 3x-ui panel connection settings.
XUI_BASE_URL=http://localhost:2053
XUI_USERNAME=
XUI_PASSWORD=
XUI_INBOUND_ID=

# Comma-separated Telegram user IDs with administrator permissions.
ADMIN_IDS=

# What to do with expired 3x-ui clients: disable or delete.
XUI_EXPIRED_CLIENT_POLICY=disable
