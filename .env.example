# Telegram bot token from BotFather.
BOT_TOKEN=

# PostgreSQL connection settings.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=safetyweb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Redis connection URL.
REDIS_URL=redis://localhost:6379/0

# 3x-ui panel connection settings.
# XUI_BASE_URL must not include /login or /panel/api.
XUI_BASE_URL=https://example.com:31293/webPath
XUI_PUBLIC_HOST=example.com
XUI_SUB_BASE_URL=https://example.com/sub/
XUI_API_TOKEN=
XUI_USERNAME=
XUI_PASSWORD=
XUI_INBOUND_IDS=1,2,3,4,5
XUI_DEFAULT_TRAFFIC_GB=0
XUI_DEFAULT_LIMIT_IP=1

# Comma-separated Telegram user IDs with administrator permissions.
ADMIN_IDS=

# Enable free test access without creating or confirming payment requests.
TEST_MODE=false
# Development/debug only: allow referral rewards while TEST_MODE is enabled.
TEST_MODE_REFERRAL_REWARDS_ENABLED=false

# User-facing one-time trial access independent from TEST_MODE.
TRIAL_ACCESS_ENABLED=true
TRIAL_ACCESS_HOURS=2

# Referral program settings.
REFERRAL_ENABLED=true
REFERRAL_NEW_USER_BONUS_DAYS=3
REFERRAL_MONTH_1_BONUS_DAYS=3
REFERRAL_MONTH_3_BONUS_DAYS=7
REFERRAL_MONTH_6_BONUS_DAYS=14
REFERRAL_MONTH_12_BONUS_DAYS=21
REFERRAL_MAX_BONUS_DAYS_PER_MONTH=30

# Early buyer discount settings.
EARLY_BUYER_DISCOUNT_ENABLED=true
EARLY_BUYER_LIMIT=100
EARLY_BUYER_DISCOUNT_PERCENT=15

# Public support and legal document links.
SERVICE_NAME=ЛадНет
SERVICE_DISPLAY_NAME=🌏 ЛадНет | Безопасный Интернет
BOT_PUBLIC_URL=https://t.me/LadnetBot

SUPPORT_USERNAME=@arbelin94
SUPPORT_SECOND_USERNAME=@BamboleiloO87
SUPPORT_EMAIL=catcodework@gmail.com

PRIVACY_POLICY_URL=https://telegra.ph/Politika-konfidencialnosti-LadNet-06-16
TERMS_URL=https://telegra.ph/Polzovatelskoe-soglashenie-LadNet-06-16
TARIFFS_URL=https://telegra.ph/Tarify-i-usloviya-oplaty-LadNet-06-16

# What to do with expired 3x-ui clients: disable or delete.
XUI_EXPIRED_CLIENT_POLICY=disable

# Payment provider: manual or platega.
PAYMENT_PROVIDER=manual

# HTTP server settings for public payment callbacks.
APP_HTTP_HOST=0.0.0.0
APP_HTTP_PORT=8000

# Platega payment provider settings.
PLATEGA_BASE_URL=https://app.platega.io
PLATEGA_MERCHANT_ID=
PLATEGA_API_KEY=
# Defaults to PLATEGA_API_KEY when unset.
PLATEGA_CALLBACK_SECRET=
PLATEGA_PAYMENT_METHOD=
PLATEGA_RETURN_URL=https://t.me/LadnetBot?start=pay_return
PLATEGA_FAILED_URL=https://t.me/LadnetBot?start=pay_failed
PLATEGA_CALLBACK_PATH=/payments/platega/callback
PLATEGA_TEST_MODE=false
PLATEGA_RECONCILE_INTERVAL_SECONDS=300
PLATEGA_WEBHOOK_RETRY_INTERVAL_SECONDS=60
# After this many processing attempts, the webhook event is marked dead for manual admin review.
PLATEGA_WEBHOOK_MAX_RETRIES=5
